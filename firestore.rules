rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Phase 1 (no downtime): preserve current open-access behavior for known
    // collections, but protect settings/config from deletion.
    match /days/{docId} {
      allow read, write: if true;
    }

    match /clients/{docId} {
      allow read, write: if true;
    }

    match /events/{docId} {
      allow read, write: if true;
    }

    match /feedbacks/{docId} {
      allow read, write: if true;
    }

    match /adminTasks/{docId} {
      allow read, write: if true;
    }

    match /schedule/{docId} {
      allow read, write: if true;
    }

    match /auditLogs/{docId} {
      allow read, write: if true;
    }

    match /settings/{docId} {
      allow read, create, update: if true;
      allow delete: if docId != 'config';
    }
  }
}
